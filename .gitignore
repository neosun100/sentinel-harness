__pycache__/
*.py[cod]
.venv/
venv/
.env
*.log
.DS_Store
evidence/*.local.json
.pytest_cache/
*.egg-info/
dist/
build/
.ruff_cache/
uv.lock

# CDK (iac-cdk/) build artifacts and deps
node_modules/
cdk.out/
cdk.out*/
cdk.out.*
*.js.map

# Terraform (iac-terraform/) local state, provider binaries, plans, and any
# *.tfvars that may carry account-specific values — NEVER commit (state can hold secrets).
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
*.auto.tfvars
crash.log

# Private, customer-specific working notes — NEVER commit (contain PII / meeting
# minutes / internal URLs). The sanitized, generic derivative is docs/ROADMAP.md.
# Patterns are intentionally NOT literal filenames, so no confidential token
# (e.g. a customer name) leaks into this tracked file.
docs/*-FIT-AND-ROADMAP.md
docs/DEVELOPMENT-GUIDE.md
# belt-and-suspenders: any doc a reviewer marks private
docs/*.private.md

# coverage artifacts
.coverage
htmlcov/

# CDK context cache (caches real account/AZ lookups — never commit)
cdk.context.json

# oh-my-claudecode local session/memory (may reference gitignored private notes — never commit)
.omc/

# Live on-account resource manifest (real ARNs/account — never commit)
.live-resources.json
