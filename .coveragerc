# Coverage configuration for sentinel-harness.
#
# WHY --include (globs below) AND NOT --source:
# The tests load the tool / specialist / long-running modules by
# ``importlib.util.spec_from_file_location`` under UNIQUE fabricated module
# names (e.g. "sigma_match_handler", "detonation_bedrock_entrypoint"), because
# those trees are flat scripts (some dirs even have a dash, e.g. "bas-runner",
# so they are not importable as packages). coverage.py's ``source`` option
# turns on import-time interception to discover modules by name; that
# interception fights the path-loading pattern (it can double-count, mis-map,
# or — as with the bas_cases "__main__" demo test — break re-``exec_module`` of
# a file under a second name). ``include`` is a pure post-hoc file-path filter:
# it never touches the import machinery, so the whole suite stays green while
# still attributing the path-loaded modules to their real files on disk.
#
# With this file present, plain
#     coverage run -m pytest tests/
#     coverage report
# Just Works (branch coverage + show-missing) with no long CLI flags.
[run]
branch = true
include =
    */tools/*
    */longrunning/*
    */specialists/*
    */sentinel_harness/*

[report]
show_missing = true
